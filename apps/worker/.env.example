SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ----- Polling cadence -----
# Data source is airplanes.live (community ADS-B feed, free, no API key).
# No published rate limit. 30s is a polite cadence that keeps markers smooth.
POLL_INTERVAL_MS=30000

# Cleanup stale rows every N ticks. At 30s cadence, 10 = every 5 min.
CLEANUP_EVERY=10

# Delay before first poll. Protects against rapid dev restarts.
STARTUP_DELAY_MS=5000
