SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Poll cadence. Anonymous OpenSky limits are harsh (~100/day as of 2024).
# 15s keeps the worker well under that ceiling. Drop to 10s only if you
# add OpenSky credentials below.
POLL_INTERVAL_MS=15000

# Cleanup stale aircraft_states rows every N ticks (15s * 20 = 5 min).
CLEANUP_EVERY=20

# Delay the first poll so rapid dev restarts (tsx watch) don't rack up 429s.
STARTUP_DELAY_MS=15000

# Optional OpenSky account — register free at https://opensky-network.org
# With credentials you get ~4000 credits/day and can run at 10s.
# OPENSKY_USERNAME=
# OPENSKY_PASSWORD=
