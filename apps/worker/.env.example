SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ----- Polling cadence -----
# OpenSky charges API credits per call. Global /states/all = 4 credits.
# Pick a cadence that fits inside your daily credit budget:
#
#   anonymous (400 credits/day):  POLL_INTERVAL_MS=900000   (15 min, 96 polls)
#   registered (4000/day):        POLL_INTERVAL_MS=90000    (90s, 960 polls)
#   academic   (8000/day):        POLL_INTERVAL_MS=45000    (45s, 1920 polls)
#
# Minimum anonymous interval is 10 s regardless of budget.
POLL_INTERVAL_MS=900000

# Cleanup stale aircraft rows every N ticks. At 15 min cadence, 4 = hourly.
CLEANUP_EVERY=4

# Delay before first poll. Protects against rapid dev restarts stacking 429s.
STARTUP_DELAY_MS=30000

# Optional OpenSky account — register free at https://opensky-network.org
# then generate API client credentials at:
#   https://opensky-network.org/my-opensky/account
# With auth you get 4000 credits/day (1000 global /states/all calls).
# OPENSKY_CLIENT_ID=
# OPENSKY_CLIENT_SECRET=
#
# Legacy basic-auth (still works for pre-2024 accounts):
# OPENSKY_USERNAME=
# OPENSKY_PASSWORD=
